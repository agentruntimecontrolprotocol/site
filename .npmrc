# FontAwesome Pro private registry (matches www). The @fortawesome scope is
# served from npm.fontawesome.com and gated on FONTAWESOME_NPM_AUTH_TOKEN, which
# must be present in the install environment (locally and in CI/Vercel).
@fortawesome:registry=https://npm.fontawesome.com/
//npm.fontawesome.com/:_authToken=${FONTAWESOME_NPM_AUTH_TOKEN}

auto-install-peers=true
