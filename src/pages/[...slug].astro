---
import { render } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import DocsBreadcrumb from '../components/DocsBreadcrumb.astro';
import DocsToc from '../components/DocsToc.astro';
import PageActions from '../components/PageActions.astro';
import {
  getDocsEntries,
  buildNavTree,
  langNavFor,
  groupLangNav,
  currentLangFor,
  sectionLabel,
  buildToc,
  entryToPath,
} from '../lib/docs-nav';

export async function getStaticPaths() {
  const entries = await getDocsEntries();
  const tree = buildNavTree(entries);
  // Cache the grouped per-language nav so we don't re-dedupe/re-bucket per page.
  const navByLang = new Map<string, ReturnType<typeof groupLangNav>>();

  return entries.flatMap((entry) => {
    const path = entryToPath(entry.id);
    if (path === '/') return []; // home is Step 6, not this route
    const lang = currentLangFor(path);
    if (!navByLang.has(lang)) navByLang.set(lang, groupLangNav(langNavFor(tree, lang), lang));
    return [{ params: { slug: path.slice(1) }, props: { entry, path, lang, navSections: navByLang.get(lang)! } }];
  });
}

const { entry, path, lang, navSections } = Astro.props;
const { Content, headings } = await render(entry);

const toc = buildToc(headings);
const title = entry.data.title ?? headings.find((h) => h.depth === 1)?.text ?? 'Documentation';
// sectionLabel is wired into SEO in Step 7; computed here so it's available.
const section = sectionLabel(path);
---

<DocsLayout path={path} navSections={navSections} currentLang={lang} title={title}>
  <div class="mx-auto max-w-3xl px-5 py-8 sm:px-8 xl:flex xl:max-w-[64rem] xl:gap-12 wide:px-12 wide:py-10">
    <div class="min-w-0 max-w-3xl xl:flex-1">
      <div class="mb-4 flex justify-end">
        <PageActions path={path} />
      </div>
      <DocsBreadcrumb path={path} />
      <article class="prose" data-section={section}>
        <Content />
      </article>
    </div>
    {toc.length > 0 && <DocsToc links={toc} class="hidden w-52 shrink-0 xl:block" />}
  </div>
</DocsLayout>
