---
// TEMPORARY Step 2 smoke route — validates Markdoc + Shiki dual-theme rendering
// (headings w/ slug ids, GFM table, blockquote, fenced code). Real docs routing
// is Step 3; this page can be removed once that lands.
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entry = await getEntry('docs', '_smoke');
if (!entry) throw new Error('smoke fixture src/content/docs/_smoke.mdoc not found');
const { Content, headings } = await render(entry);
---

<BaseLayout title="Markdoc smoke test">
  <main class="relative z-10 max-w-[42rem] mx-auto px-6 pb-24">
    <p class="label">Resolved heading slugs: {headings.map((h) => h.slug).join(', ')}</p>
    <article class="prose">
      <Content />
    </article>
  </main>
</BaseLayout>
