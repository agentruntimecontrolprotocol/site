---
// PageActions.astro — the LLM affordances from the Stripe audit, done statically:
// "Copy for LLM" (copies the page's raw markdown) and "View as Markdown" (opens
// the per-page `.md` artifact). "Ask about this section" is intentionally omitted
// until a concrete target is configured — a dead control reads as broken.
interface Props {
  path: string;
}

const { path } = Astro.props;
const mdHref = `${path}.md`;
const actionClass =
  'inline-flex items-center gap-1.5 rounded px-1.5 py-1 transition-colors hover:text-accent focus-visible:text-accent';
---

<div
  class="flex items-center gap-2 font-mono text-mini text-muted"
  data-page-actions
  data-md={mdHref}
>
  <button type="button" data-copy-md class={actionClass} aria-label="Copy page as Markdown for an LLM">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
    <span data-label>Copy for LLM</span>
  </button>
  <span class="text-line" aria-hidden="true">·</span>
  <a href={mdHref} target="_blank" rel="noopener" class={actionClass}>
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><path d="M14 2v6h6" /></svg>
    View as Markdown
  </a>
</div>

<script>
  // Fetch the page's raw `.md` and copy it. One delegated listener (deduped by
  // Astro across pages).
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-copy-md]');
    if (!btn) return;
    const wrap = btn.closest<HTMLElement>('[data-page-actions]');
    const href = wrap?.dataset.md;
    if (!href) return;
    const label = btn.querySelector<HTMLElement>('[data-label]');
    try {
      const text = await (await fetch(href)).text();
      await navigator.clipboard.writeText(text);
      if (label) {
        const prev = label.textContent;
        label.textContent = 'Copied';
        setTimeout(() => (label.textContent = prev), 1200);
      }
    } catch {
      if (label) {
        const prev = label.textContent;
        label.textContent = 'Copy failed';
        setTimeout(() => (label.textContent = prev), 1200);
      }
    }
  });
</script>
