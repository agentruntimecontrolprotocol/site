---
import { SITE } from '../consts';
import { LANG_ITEMS, type NavSection } from '../lib/docs-nav';

interface Props {
  navSections: NavSection[];
  currentLang: string;
  path: string;
}

const { navSections, currentLang, path } = Astro.props;

function isActive(p: string, exact = false) {
  return exact ? path === p : path === p || path.startsWith(p + '/');
}
// Open on the active trail by default; client script handles manual toggles.
const isOpen = (p: string) => isActive(p);

const parentBase = 'flex-1 min-w-0 block px-3 py-2 text-[0.9375rem] rounded truncate transition-colors min-h-8';
const parentLinkClass = (p: string) =>
  isActive(p)
    ? `${parentBase} bg-paper text-accent font-medium`
    : `${parentBase} text-ink hover:bg-paper hover:text-ink`;

const childBase = 'block px-3 py-1.5 text-[0.9375rem] rounded transition-colors min-h-8';
const childLinkClass = (p: string) =>
  isActive(p, true)
    ? `${childBase} bg-paper text-accent font-medium`
    : `${childBase} text-muted hover:bg-paper hover:text-ink`;
---

<aside
  id="docs-nav"
  class="fixed inset-y-0 left-0 z-40 w-70 -translate-x-full transition-transform duration-200
         flex h-[100dvh] flex-col overflow-hidden border-r border-line bg-bg
         wide:static wide:z-auto wide:h-auto wide:translate-x-0"
>
  <!-- FIXED TOP ZONE — brand · search · language. Does not scroll (Stripe ~91px). -->
  <div class="shrink-0">
    <!-- brand row aligns with the navbar height (h-14) on the right -->
    <div class="flex h-14 items-center gap-3 border-b border-line px-4">
      <a
        href="/"
        class="inline-flex items-center font-mono text-[1.02rem] font-semibold tracking-[0.04em] text-ink no-underline"
      >
        {SITE.name}<span class="arcp-caret"></span>
      </a>
    </div>

    <!-- search trigger — layout placeholder; backend (Pagefind) is deferred, so
         it ships disabled with a "soon" affordance rather than a dead control. -->
    <div class="px-3 pt-3">
      <button
        id="docs-search-trigger"
        type="button"
        disabled
        title="Search is coming soon"
        class="flex w-full items-center gap-2 rounded border border-line bg-paper px-3 py-2 text-small text-muted opacity-70 cursor-not-allowed"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
        <span class="flex-1 text-left">Find anything</span>
        <span class="rounded border border-line px-1.5 py-0.5 font-mono text-mini text-faint">soon</span>
      </button>
    </div>

    <!-- language switcher — NAVIGATION: picking a language re-routes /<lang>. -->
    <div class="px-4 py-3 border-b border-line">
      <p class="mb-2 label">Language</p>

      <div class="hidden wide:flex flex-wrap gap-1.5">
        {
          LANG_ITEMS.map((item) => (
            <a
              href={`/${item.value}`}
              rel="nofollow noreferrer"
              class:list={['lang-chip', { 'is-active': currentLang === item.value }]}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <select
        id="lang-select"
        class="w-full wide:hidden rounded border border-line bg-paper px-2 py-1.5 font-mono text-small text-ink"
        aria-label="Select language"
      >
        {
          LANG_ITEMS.map((item) => (
            <option value={item.value} selected={currentLang === item.value}>
              {item.label}
            </option>
          ))
        }
      </select>
    </div>
  </div>

  <!-- NAV TREE — the only part of the sidebar that scrolls. -->
  <nav
    id="docs-nav-tree"
    class="min-h-0 flex-1 overflow-y-auto overscroll-contain px-3 py-4"
    tabindex="0"
    role="region"
    aria-label="Navigation"
  >
    {
      navSections.map((section) => (
        <div class="mb-4">
          {section.kind === 'group' && (
            <p class="label px-3 mb-1.5">{section.label}</p>
          )}
          <ul class="space-y-0.5">
            {section.items.map((item) => (
          <li>
            <div class="flex items-center gap-0.5">
              {item.hasPage === false && item.children?.length ? (
                // synthetic parent (folder w/o index): toggle, don't navigate
                <button
                  type="button"
                  class:list={[parentLinkClass(item.path), 'nav-toggle text-left']}
                  data-target={item.path}
                  data-active={isActive(item.path) ? 'true' : undefined}
                  aria-expanded={isOpen(item.path) ? 'true' : 'false'}
                >
                  {item.title}
                </button>
              ) : (
                <a
                  href={item.path}
                  class={parentLinkClass(item.path)}
                  data-active={isActive(item.path) ? 'true' : undefined}
                  aria-current={isActive(item.path) ? 'page' : undefined}
                >
                  {item.title}
                </a>
              )}
              {item.children?.length ? (
                <button
                  type="button"
                  class="nav-toggle shrink-0 inline-flex size-8 items-center justify-center rounded text-muted transition-colors hover:bg-paper hover:text-ink"
                  data-target={item.path}
                  aria-expanded={isOpen(item.path) ? 'true' : 'false'}
                  aria-label={`Toggle ${item.title}`}
                >
                  <svg
                    class:list={['nav-chevron transition-transform duration-150', { 'rotate-90': isOpen(item.path) }]}
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </button>
              ) : null}
            </div>
            {item.children?.length ? (
              <ul
                class:list={[
                  'nav-children ml-3 mt-0.5 mb-1 space-y-0.5 border-l border-line pl-3',
                  { hidden: !isOpen(item.path) },
                ]}
                data-group={item.path}
              >
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.path}
                      class={childLinkClass(child.path)}
                      data-active={isActive(child.path, true) ? 'true' : undefined}
                      aria-current={isActive(child.path, true) ? 'page' : undefined}
                    >
                      {child.title}
                    </a>
                  </li>
                ))}
              </ul>
            ) : null}
          </li>
            ))}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>
