---
import type { TocLink } from '../lib/docs-nav';

interface Props {
  links: TocLink[];
  class?: string;
}

const { links, class: className } = Astro.props;
---

<nav
  aria-label="On this page"
  class:list={['sticky top-[4.75rem] max-h-[calc(100vh-7rem)] self-start overflow-y-auto', className]}
>
  <p class="mb-3 font-mono text-mini uppercase tracking-wider text-muted">On this page</p>
  <ul class="space-y-1 border-l border-line text-sm">
    {
      links.map((l) => (
        <li>
          <a
            href={`#${l.id}`}
            class="-ml-px block border-l border-transparent py-0.5 pl-3 text-ink-soft transition-colors hover:border-accent hover:text-accent active:text-accent"
          >
            {l.text}
          </a>
          {l.children?.length ? (
            <ul class="space-y-1">
              {l.children.map((c) => (
                <li>
                  <a
                    href={`#${c.id}`}
                    class="-ml-px block border-l border-transparent py-0.5 pl-6 text-muted transition-colors hover:border-accent hover:text-accent active:text-accent"
                  >
                    {c.text}
                  </a>
                </li>
              ))}
            </ul>
          ) : null}
        </li>
      ))
    }
  </ul>
</nav>
