---
interface Props {
  columns: Array<{
    heading: string;
    tone: 'positive' | 'neutral';
    items: Array<{ label: string; note?: string }>;
  }>;
}
const { columns } = Astro.props;
---

<div class="reveal md:ml-28 max-w-[46rem] grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
  {
    columns.map((col) => (
      <div>
        <h3
          class:list={[
            'font-mono text-[0.74rem] tracking-mono-wide uppercase font-medium mb-[1.1rem] pb-[0.7rem] border-b border-line',
            col.tone === 'positive' ? 'text-ink' : 'text-muted',
          ]}
        >
          {col.heading}
        </h3>
        <ul class="list-none m-0 p-0">
          {col.items.map((item) => (
            <li
              class:list={[
                'text-[0.97rem] leading-[1.45] py-2 pl-[1.3rem] relative',
                col.tone === 'positive' ? 'text-ink-soft' : 'text-muted',
              ]}
            >
              <span
                class:list={[
                  'absolute left-0 font-mono text-[0.85rem]',
                  col.tone === 'positive' ? 'text-accent' : 'text-faint',
                ]}
              >
                {col.tone === 'positive' ? '+' : '−'}
              </span>
              {item.label}
              {item.note && (
                <em class="not-italic font-mono text-[0.85em] text-accent-dim">{item.note}</em>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
