---
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import AppHeader from '../components/AppHeader.astro';
import type { NavItem } from '../lib/docs-nav';

interface Props {
  path: string;
  langNav: NavItem[];
  currentLang: string;
  title?: string;
  description?: string;
}

const { path, langNav, currentLang, title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <AppHeader slot="header" showMenu />

  <div class="min-h-screen bg-bg text-ink">
    <div class="lg:flex">
      <div
        id="docs-overlay"
        class="hidden fixed inset-0 top-14 z-20 bg-black/40 lg:hidden"
        aria-hidden="true"
      >
      </div>

      <DocsSidebar langNav={langNav} currentLang={currentLang} path={path} />

      <main class="flex-1 min-w-0 px-5 py-8 sm:px-8 lg:px-12 lg:py-10">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>

<script>
  // Mobile drawer — the hamburger lives in AppHeader and fires `toggle-nav`.
  const aside = document.getElementById('docs-nav');
  const overlay = document.getElementById('docs-overlay');

  function setDrawer(open: boolean) {
    aside?.classList.toggle('-translate-x-full', !open);
    overlay?.classList.toggle('hidden', !open);
  }
  document.addEventListener('toggle-nav', () =>
    setDrawer(aside?.classList.contains('-translate-x-full') ?? false),
  );
  overlay?.addEventListener('click', () => setDrawer(false));

  // Collapsible nav groups (manual toggle on top of the active-trail default)
  document.querySelectorAll<HTMLButtonElement>('.nav-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      if (!target) return;
      const group = document.querySelector(`.nav-children[data-group="${CSS.escape(target)}"]`);
      const chevron = btn.querySelector('.nav-chevron');
      if (!group) return;
      group.classList.toggle('hidden');
      const open = !group.classList.contains('hidden');
      btn.setAttribute('aria-expanded', String(open));
      chevron?.classList.toggle('rotate-90', open);
    });
  });

  // Mobile language switch
  document.getElementById('lang-select')?.addEventListener('change', (e) => {
    const value = (e.target as HTMLSelectElement).value;
    if (value) window.location.href = '/' + value;
  });

  // Keep the active sidebar row in view on deep pages
  document
    .querySelector('#docs-nav [data-active="true"]')
    ?.scrollIntoView({ block: 'nearest' });
</script>
