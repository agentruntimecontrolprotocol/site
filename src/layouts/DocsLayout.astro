---
import BaseLayout from './BaseLayout.astro';
import AppShell from '../components/AppShell.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import DocsNavbar from '../components/DocsNavbar.astro';
import type { NavSection } from '../lib/docs-nav';

interface Props {
  path: string;
  navSections: NavSection[];
  currentLang: string;
  title?: string;
  description?: string;
}

const { path, navSections, currentLang, title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  {/* suppress BaseLayout's fallback header — the navbar lives inside the shell */}
  <Fragment slot="header" />

  <AppShell>
    <DocsSidebar slot="sidebar" navSections={navSections} currentLang={currentLang} path={path} />
    <DocsNavbar slot="navbar" currentLang={currentLang} path={path} />

    <slot />
  </AppShell>

  {/* mobile drawer scrim — only below wide:, where the sidebar is off-canvas */}
  <div
    id="docs-overlay"
    class="hidden fixed inset-0 z-30 bg-black/40 wide:hidden"
    aria-hidden="true"
  >
  </div>
</BaseLayout>

<script>
  // ── Mobile drawer ────────────────────────────────────────────────────────
  // The hamburger lives in DocsNavbar and fires `toggle-nav`; the drawer + scrim
  // live here. Below `wide:` the sidebar is a fixed off-canvas drawer.
  const aside = document.getElementById('docs-nav');
  const overlay = document.getElementById('docs-overlay');
  const menuBtn = document.getElementById('docs-menu-btn');

  function setDrawer(open: boolean) {
    aside?.classList.toggle('-translate-x-full', !open);
    overlay?.classList.toggle('hidden', !open);
    document.documentElement.classList.toggle('drawer-open', open);
    menuBtn?.setAttribute('aria-expanded', String(open));
  }
  document.addEventListener('toggle-nav', () =>
    setDrawer(aside?.classList.contains('-translate-x-full') ?? false),
  );
  overlay?.addEventListener('click', () => setDrawer(false));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setDrawer(false);
  });

  // ── Collapsible nav groups (manual toggle atop the active-trail default) ──
  document.querySelectorAll<HTMLButtonElement>('.nav-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      if (!target) return;
      const group = document.querySelector(`.nav-children[data-group="${CSS.escape(target)}"]`);
      const chevron = btn.querySelector('.nav-chevron');
      if (!group) return;
      group.classList.toggle('hidden');
      const open = !group.classList.contains('hidden');
      btn.setAttribute('aria-expanded', String(open));
      chevron?.classList.toggle('rotate-90', open);
    });
  });

  // ── Mobile language switch (the <select> fallback below wide:) ───────────
  document.getElementById('lang-select')?.addEventListener('change', (e) => {
    const value = (e.target as HTMLSelectElement).value;
    if (value) window.location.href = '/' + value;
  });

  // ── Keep the active row in view — scoped to the inner nav-tree scroller ──
  document
    .querySelector('#docs-nav-tree [data-active="true"]')
    ?.scrollIntoView({ block: 'nearest' });

  // ── Reference pages: inject hover permalink anchors into member headings ──
  // Astro assigns the heading ids; we enhance them on the client (the same ids
  // the TOC uses), so each reference row is deep-linkable. Gated to api pages.
  const refArticle = document.querySelector<HTMLElement>('article[data-section$="API"]');
  if (refArticle) {
    refArticle.querySelectorAll<HTMLElement>('h2[id], h3[id], h4[id]').forEach((h) => {
      if (h.querySelector('.heading-anchor')) return;
      const a = document.createElement('a');
      a.className = 'heading-anchor';
      a.href = `#${h.id}`;
      a.setAttribute('aria-label', `Permalink to ${h.id}`);
      a.textContent = '#';
      h.prepend(a);
    });
  }
</script>
