---
import { SITE, BRAND_COLOR } from '../consts';
import ThemeToggle from '../components/ThemeToggle.astro';

// Global design system + self-hosted fonts (loaded once for every route).
import '../styles/fonts.css';
import '../styles/main.css';
import '../styles/prose.css';
import '../styles/shiki.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const pageTitle = title ? `${title} · ${SITE.name}` : SITE.name;
---

<!doctype html>
<html lang={SITE.defaultLocale} data-code-lang="spec">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- No-FOUC theme: run before first paint, before any deferred JS. Read the
         explicit choice from localStorage, else fall back to the OS preference,
         and set `.light` / `.dark` EXPLICITLY so a stored choice wins over a
         conflicting OS preference (mirrors the `:root:not(.light)` cascade). -->
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('arcp-theme');
          const dark = stored
            ? stored === 'dark'
            : window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.classList.add(dark ? 'dark' : 'light');
        } catch {
          /* storage blocked — fall through to the CSS media-query default */
        }
      })();
    </script>

    <!-- No-FOUC code-language view: rewrite `data-code-lang` from the stored
         preference before first paint so curated code panels show the reader's
         chosen SDK with no flash. SSR default is `spec` (the wire/curl view). -->
    <script is:inline>
      try {
        const v = localStorage.getItem('arcp:code-lang');
        if (v) document.documentElement.dataset.codeLang = v;
      } catch {
        /* storage blocked — keep the SSR `spec` default */
      }
    </script>

    <!-- Favicon wiring mirrored from www/nuxt.config.ts -> app.head.link -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color={BRAND_COLOR} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, SITE.url)} />
  </head>
  <body>
    <slot name="header">
      <header
        class="relative z-10 flex items-center justify-between max-w-[42rem] mx-auto px-6 py-5"
      >
        <span class="font-mono text-ink font-medium">{SITE.name}</span>
        <ThemeToggle />
      </header>
    </slot>
    <slot />
  </body>
</html>
